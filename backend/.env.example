# ============================================================
# NAVKAR QR MANAGER - Backend Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# QR Code Base URL
QR_BASE_URL=https://qr.navkarplywood.com

# CORS - comma separated allowed origins
CORS_ORIGINS=http://localhost:5173,https://qr.navkarplywood.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# IP Geolocation API (optional - ipapi.co is free for 1k/day)
GEO_API_URL=https://ipapi.co

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info
