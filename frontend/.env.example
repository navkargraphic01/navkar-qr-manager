# ============================================================
# NAVKAR QR MANAGER - Frontend Environment Variables
# 1. Copy this file:   cp .env.example .env
# 2. Fill in your real values below
# 3. NEVER commit your .env file to GitHub!
# ============================================================

# Your Supabase project URL
# Find this at: supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (safe to use in browser)
# Find this at: supabase.com → Your Project → Settings → API → anon public
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Your backend API URL
# Local development: http://localhost:3001/api
# Production: https://your-backend.vercel.app/api
VITE_API_URL=http://localhost:3001/api

# Base URL for QR codes (what gets encoded in QR)
# Local development: http://localhost:3001
# Production: https://qr.navkarplywood.com
VITE_QR_BASE_URL=http://localhost:3001
